# ---- window geometry -----------------------------------------------------
def usable_area():
    """Return (left, top, right, bottom) of the screen minus menu bar + Dock."""
    try:
        b = osa('tell application "Finder" to get bounds of window of desktop')
        L, T, R, B = [int(x) for x in b.strip().split(", ")]
    except Exception:
        L, T, R, B = 0, 0, 1512, 982

    top = T + 38          # menu bar (notch-safe)
    left, right, bottom = L, R, B

    # Dock: pull autohide / edge / size in one call
    try:
        p = osa('tell application "System Events" to tell dock preferences '
                'to get {autohide, screen edge, dock size}')
        fields = [f.strip() for f in p.strip().split(",")]
        autohide = fields[0].lower() == "true"
        edge = fields[1].lower()
        try:
            size = float(fields[2])
        except (ValueError, IndexError):
            size = 0.4
    except Exception:
        autohide, edge, size = False, "bottom", 0.4

    if not autohide:
        reserve = int(16 + size * 112) + 24    # dock tile px + padding
        if edge == "bottom":
            bottom -= reserve
        elif edge == "left":
            left += reserve
        elif edge == "right":
            right -= reserve
    else:
        bottom -= 6
    return (left, top, right, bottom)


def grid_cells(n, area, gap=8):
    """Balanced, full-width grid. Returns n rectangles (l, t, r, b)."""
    L, T, R, B = area
    W, H = R - L, B - T
    aspect = W / max(H, 1)
    cols = max(1, round(math.sqrt(n * aspect)))
    rows = max(1, math.ceil(n / cols))
    base, extra = divmod(n, rows)
    counts = [base + (1 if i < extra else 0) for i in range(rows)]
    rh = H / rows
    cells = []
    for r, cnt in enumerate(counts):
        cw = W / cnt
        for ci in range(cnt):
            l = L + ci * cw
            t = T + r * rh
            cells.append((round(l + gap / 2), round(t + gap / 2),
                          round(l + cw - gap / 2), round(t + rh - gap / 2)))
    return cells


def fixed_grid_cells(n, area, cols, gap=8):
    L, T, R, B = area
    W, H = R - L, B - T
    rows = max(1, math.ceil(n / cols))
    rh = H / rows
    cw = W / cols
    cells = []
    for i in range(n):
        r, ci = divmod(i, cols)
        l, t = L + ci * cw, T + r * rh
        cells.append((round(l + gap / 2), round(t + gap / 2),
                      round(l + cw - gap / 2), round(t + rh - gap / 2)))
    return cells


def cascade_cells(n, area, step=30):
    """Diagonal stagger; wraps into a new column when it nears the bottom."""
    L, T, R, B = area
    win_w = min(760, R - L - 40)
    win_h = min(460, B - T - 40)
    cells = []
    col_x, y = L, T
    for i in range(n):
        if y + win_h > B:                 # start a new diagonal column
            col_x += win_w // 2
            if col_x + win_w > R:
                col_x = L
            y = T
        l, t = col_x, y
        cells.append((l, t, l + win_w, t + win_h))
        col_x += step
        y += step
    return cells


def master_stack_cells(ids, master_id, area, master_frac=0.64, gap=8):
    """Big 'master' pane on the left + the rest in a side stack.
    Returns {window_id: (l, t, r, b)}."""
    L, T, R, B = area
    W, H = R - L, B - T
    cells = {}
    if len(ids) <= 1:
        cells[master_id] = (round(L + gap / 2), round(T + gap / 2),
                            round(R - gap / 2), round(B - gap / 2))
        return cells

    master_w = round(W * master_frac)
    cells[master_id] = (round(L + gap / 2), round(T + gap / 2),
                        round(L + master_w - gap / 2), round(B - gap / 2))

    stack = [i for i in ids if i != master_id]
    sx0, sw = L + master_w, W - master_w
    scols = max(1, math.ceil(len(stack) / 8))   # 2nd column past 8 windows
    srows = max(1, math.ceil(len(stack) / scols))
    cw, ch = sw / scols, H / srows
    for k, sid in enumerate(stack):
        r, ci = divmod(k, scols)
        l, t = sx0 + ci * cw, T + r * ch
        cells[sid] = (round(l + gap / 2), round(t + gap / 2),
                      round(l + cw - gap / 2), round(t + ch - gap / 2))
    return cells


def master_stack_slots(n, area, master_frac=0.64, gap=8):
    """Positional slots: (master_rect, [stack_rect, ...]) with len == n-1.
    Used by follow() so a click only SWAPS two windows between fixed slots."""
    L, T, R, B = area
    W, H = R - L, B - T
    master = (round(L + gap / 2), round(T + gap / 2),
              round(R - gap / 2 if n <= 1 else L + W * master_frac - gap / 2),
              round(B - gap / 2))
    if n <= 1:
        return master, []
    sx0, sw = L + W * master_frac, W - W * master_frac
    ns = n - 1
    scols = max(1, math.ceil(ns / 8))
    srows = max(1, math.ceil(ns / scols))
    cw, ch = sw / scols, H / srows
    stack = []
    for k in range(ns):
        r, ci = divmod(k, scols)
        l, t = sx0 + ci * cw, T + r * ch
        stack.append((round(l + gap / 2), round(t + gap / 2),
                      round(l + cw - gap / 2), round(t + ch - gap / 2)))
    return master, stack


def apply_bounds(rows, cells, master_id=None, activate=True):
    """cells is either a parallel list (len == rows) or a {id: rect} dict."""
    lines = ['tell application "Terminal"']
    if activate:
        lines.append("  activate")
    if isinstance(cells, dict):
        pairs = [(r["wid"], cells[r["wid"]]) for r in rows if r["wid"] in cells]
    else:
        pairs = [(r["wid"], rect) for r, rect in zip(rows, cells)]
    for wid, (l, t, ri, b) in pairs:
        lines.append(f"  set bounds of window id {wid} to "
                     f"{{{l}, {t}, {ri}, {b}}}")
    if master_id is not None:
        lines.append(f"  set index of window id {master_id} to 1")
    lines.append("end tell")
    osa("\n".join(lines))


def front_and_count():
    """One cheap query: (front window id, window count)."""
    out = osa('tell application "Terminal" to return '
              '((id of front window) as string) & "/" & '
              '((count of windows) as string)')
    try:
        a, b = out.strip().split("/")
        return int(a), int(b)
    except Exception:
        return None, 0


def do_tile(layout="grid", cols=None):
    rows = collect()
    if not rows:
        print("No open Terminal windows to arrange.")
        return 1
    area = usable_area()
    if layout == "stack":
        cells = cascade_cells(len(rows), area)
        how = "cascade"
    elif cols:
        cells = fixed_grid_cells(len(rows), area, cols)
        how = f"{cols}-column grid"
    else:
        cells = grid_cells(len(rows), area)
        how = "grid"
    apply_bounds(rows, cells)
    color = sys.stdout.isatty()
    print(c(f"Arranged {len(rows)} Terminal windows into a {how}.", "92", color))
    print(c("Numbered left-to-right, top-to-bottom — same as 'deck'. "
            "Re-run after opening/closing windows.", "90", color))
    return 0


def do_main(n=None):
    """One-shot: make window #n (or the current front window) the big master."""
    rows = collect()
    if not rows:
        print("No open Terminal windows.")
        return 1
    if n is None:
        fid, _ = front_and_count()
        master = fid if any(r["wid"] == fid for r in rows) else rows[-1]["wid"]
    else:
        m = [r for r in rows if r["n"] == n]
        if not m:
            print(f"No window #{n} (there are {len(rows)}).")
            return 1
        master = m[0]["wid"]
    cells = master_stack_cells([r["wid"] for r in rows], master, usable_area())
    apply_bounds(rows, cells, master_id=master)
    color = sys.stdout.isatty()
    task = next(r["task"] for r in rows if r["wid"] == master)
    print(c(f"Enlarged: {task}", "92", color))
    print(c("The rest are stacked on the right — click any to swap it big "
            "(or run 'deck follow' for automatic click-to-enlarge).",
            "90", color))
    return 0


def _full_layout(master_frac):
    """Lay every window into master+stack slots. Returns tracking state."""
    rows = collect()
    ids = [r["wid"] for r in rows]
    if not ids:
        return None
    fid, _ = front_and_count()
    master = fid if fid in ids else ids[0]
    m_rect, s_rects = master_stack_slots(len(ids), usable_area(), master_frac)
    stack_ids = [i for i in ids if i != master]
    slot = {master: "M"}
    cells = {master: m_rect}
    for k, sid in enumerate(stack_ids):
        slot[sid] = k
        cells[sid] = s_rects[k]
    apply_bounds(rows, cells, master_id=master, activate=False)
    return {"slot": slot, "m_rect": m_rect, "s_rects": s_rects,
            "master": master, "ids": set(ids)}


def do_follow(master_frac=0.64, interval=0.25):
    """Live loop: the window you click swaps into the big 'master' pane.
    Only two windows move per click (clicked -> master, old master -> its slot)."""
    color = sys.stdout.isatty()
    print(c("● click-to-enlarge running — click any small window and it "
            "swaps into the big pane.", "92", color))
    st = _full_layout(master_frac)
    while st is None:
        time.sleep(1.0)
        st = _full_layout(master_frac)
    try:
        while True:
            fid, cnt = front_and_count()
            if fid is None:
                time.sleep(interval)
                continue
            # window opened/closed, or an untracked window came forward
            if cnt != len(st["ids"]) or fid not in st["slot"]:
                ns = _full_layout(master_frac)
                if ns:
                    st = ns
                time.sleep(interval)
                continue
            if fid != st["master"]:
                s = st["slot"][fid]            # stack slot the click vacates
                old = st["master"]
                st["slot"][fid] = "M"
                st["slot"][old] = s
                ml = st["m_rect"]
                sl = st["s_rects"][s]
                osa('tell application "Terminal"\n'
                    f'  set bounds of window id {fid} to '
                    f'{{{ml[0]}, {ml[1]}, {ml[2]}, {ml[3]}}}\n'
                    f'  set bounds of window id {old} to '
                    f'{{{sl[0]}, {sl[1]}, {sl[2]}, {sl[3]}}}\n'
                    f'  set index of window id {fid} to 1\n'
                    'end tell')
                st["master"] = fid
            time.sleep(interval)
    except KeyboardInterrupt:
        print(c("\nfollow stopped.", "90", color))


# ---- background daemon control for follow --------------------------------
def follow_pid():
    try:
        pid = int(open(PID_PATH).read().strip())
        os.kill(pid, 0)            # probe: raises if not alive
        return pid
    except Exception:
        return None


def follow_start(master_frac=0.64):
    pid = follow_pid()
    if pid:
        print(f"click-to-enlarge already ON (pid {pid}). "
              "Stop it with: deck follow stop")
        return 0
    log = open(LOG_PATH, "a")
    p = subprocess.Popen(
        [sys.executable, os.path.abspath(__file__), "_followd", str(master_frac)],
        stdout=log, stderr=subprocess.STDOUT, stdin=subprocess.DEVNULL,
        start_new_session=True)
    with open(PID_PATH, "w") as f:
        f.write(str(p.pid))
    color = sys.stdout.isatty()
    print(c("✓ click-to-enlarge is ON (running in the background).", "92", color))
    print(c("  Click any small window — it swaps into the big pane you type in.",
            "90", color))
    print(c("  Turn off with:  deck follow stop", "90", color))
    return 0


def follow_stop():
    pid = follow_pid()
    if not pid:
        print("click-to-enlarge is not running.")
        try:
            os.remove(PID_PATH)
        except OSError:
            pass
        return 0
    try:
        os.kill(pid, signal.SIGTERM)
    except OSError:
        pass
    try:
        os.remove(PID_PATH)
    except OSError:
        pass
    print("click-to-enlarge OFF. Windows stay where they are "
          "(run 'deck tile' to re-grid).")
    return 0


def follow_status():
    pid = follow_pid()
    print(f"click-to-enlarge: ON (pid {pid})" if pid else "click-to-enlarge: OFF")
    return 0


# ---- actions -------------------------------------------------------------
def do_go(n):
    rows = collect()
    match = [r for r in rows if r["n"] == n]
    if not match:
        print(f"No window #{n}. There are {len(rows)} open "
              f"(run 'deck' to list them).")
        return 1
    wid = match[0]["wid"]
    osa(f'''tell application "Terminal"
      activate
      set index of window id {wid} to 1
    end tell''')
    print(f"→ #{n}: {match[0]['task']}")
    return 0


def do_table_once(color):
    sys.stdout.write(render_table(collect(), color))


def do_watch(interval):
    try:
        while True:
            sys.stdout.write("\033[2J\033[H")           # clear + home
            sys.stdout.write(render_table(collect(), True))
            sys.stdout.write(c("\n  ↻ live — every "
                               f"{interval}s — Ctrl-C to stop", "90", True)
                             + "\n")
            sys.stdout.flush()
            time.sleep(interval)
    except KeyboardInterrupt:
        sys.stdout.write("\n")


def do_html(watch=False, interval=3):
    def write_once():
        rows = collect()
        with open(HTML_PATH, "w", encoding="utf-8") as f:
            f.write(render_html(rows, refresh=interval if watch else None))
        return rows
    rows = write_once()
    subprocess.run(["open", HTML_PATH])
    print(f"Dashboard → {HTML_PATH}  ({len(rows)} windows)")
    if watch:
        print(f"Live: regenerating every {interval}s, page auto-refreshes. "
              "Ctrl-C to stop.")
        try:
            while True:
                time.sleep(interval)
                write_once()
        except KeyboardInterrupt:
            print("\nstopped.")


HELP = __doc__


def main():
    args = sys.argv[1:]
    color = sys.stdout.isatty()

    if not args:
        return do_table_once(color)

    cmd = args[0].lower()
    if cmd in ("help", "-h", "--help"):
        print(HELP)
    elif cmd in ("version", "-v", "--version"):
        print(f"deck {VERSION}")
    elif cmd == "go":
        if len(args) < 2 or not args[1].isdigit():
            print("Usage: deck go <number>")
            return 1
        return do_go(int(args[1]))
    elif cmd in ("tile", "grid", "arrange"):
        cols = int(args[1]) if len(args) > 1 and args[1].isdigit() else None
        return do_tile("grid", cols)
    elif cmd in ("stack", "cascade"):
        return do_tile("stack")
    elif cmd in ("follow", "live"):
        sub = args[1].lower() if len(args) > 1 else ""
        if sub in ("stop", "off"):
            return follow_stop()
        if sub == "status":
            return follow_status()
        if sub in ("fg", "--fg"):
            do_follow()                       # blocking, in this tab
        else:
            mf = float(args[1]) / 100.0 if (len(args) > 1 and
                                            args[1].isdigit()) else 0.64
            return follow_start(mf)
    elif cmd in ("unfollow", "stop"):
        return follow_stop()
    elif cmd == "_followd":                    # internal: daemon body
        mf = float(args[1]) if len(args) > 1 else 0.64
        do_follow(master_frac=mf)
    elif cmd in ("main", "big", "focus"):
        n = int(args[1]) if len(args) > 1 and args[1].isdigit() else None
        return do_main(n)
    elif cmd == "watch":
        interval = (float(args[1]) if len(args) > 1 and
                    args[1].replace(".", "", 1).isdigit() else 2.0)
        do_watch(interval)
    elif cmd == "html":
        watch = len(args) > 1 and args[1].lower() == "watch"
        do_html(watch=watch)
    else:
        print(f"Unknown command: {cmd}\n")
        print(HELP)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main() or 0)
