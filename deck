    counts = {}
    for r in rows:
        counts[r["status"]] = counts.get(r["status"], 0) + 1
        color, label = palette.get(r["status"], palette["other"])
        pulse = "pulse" if r["status"] in ("working", "busy") else ""
        task = (r["task"].replace("&", "&amp;").replace("<", "&lt;")
                .replace(">", "&gt;"))
