#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
deck — a clean overview, tiler, and click-to-enlarge for macOS Terminal.app.

When you have a pile of overlapping Terminal windows (great for juggling many
Claude Code / AI-agent sessions), deck lays them out so you can see and click
every one — and optionally swaps whichever you click into a big working pane.

Each window shows up with:
  • a live status   (working / waiting / shell)  read from the title glyph
  • how long idle   (no output to that tty)
  • the window task  (e.g. the title Claude Code set)
  • what's running   (claude, caffeinate, node, plain shell ...)

USAGE
  deck                  Print a clean table of all Terminal windows (default)
  deck tile [cols]      Arrange every window into a tidy grid so they're all
                        visible and clickable (no overlap). Optional column
                        count, e.g. 'deck tile 4'
  deck stack            Cascade windows diagonally (every title bar readable)
  deck follow [pct]     Turn ON click-to-enlarge (runs in the BACKGROUND):
                        click any small window and it swaps into the big pane
                        you type in. Optional pct = big-pane width ('follow 75')
  deck follow stop      Turn it off        (aliases: 'deck stop', 'deck unfollow')
  deck follow status    Is it on?
  deck main [n]         One-shot: make window #n (or the front one) big now
  deck go <n>           Bring window number <n> to the front
  deck watch [N]        Live auto-refreshing table (default every 2 seconds)
  deck html [watch]     Build a browser dashboard and open it
  deck help             This help
  deck version          Print version

No dependencies beyond Python 3. No server, no config. Pure AppleScript control.
Project: https://github.com/noahmehrle2-prog/deck
"""

import os
import re
import sys
import math
import time
import shutil
import signal
import subprocess

VERSION = "1.0.0"

HTML_PATH = os.path.expanduser("~/.deck-dashboard.html")
PID_PATH = os.path.expanduser("~/.deck-follow.pid")
LOG_PATH = os.path.expanduser("~/.deck-follow.log")

# ---- glyph classification ------------------------------------------------
# Claude Code paints the terminal title with a spinner while working and a
# sparkle while it's idle/waiting for you. We read that glyph to get status.
# (Non-Claude windows simply fall back to "shell" — tiling works regardless.)
WAITING_GLYPHS = set("✳✶✻✽✺✦✱❋✷✸✹✴❂✵✲✫✬")


def classify(glyph, proc, task):
    """Return one of: working, waiting, shell, busy."""
    is_claude = "claude" in (proc + " " + task).lower()
    if glyph:
        c = ord(glyph[0])
        if 0x2800 <= c <= 0x28FF:          # Braille block = spinner = working
            return "working" if is_claude else "busy"
        if glyph[0] in WAITING_GLYPHS:     # sparkle = idle/ready
            return "waiting" if is_claude else "busy"
    if is_claude:
        return "waiting"
    return "shell"


# ---- data acquisition ----------------------------------------------------
OSA_LIST = r'''
tell application "Terminal"
  set out to ""
  repeat with w in windows
    set tlist to ""
    repeat with t in tabs of w
      try
        set tlist to tlist & (tty of t) & ","
      end try
    end repeat
    set out to out & (id of w) & "§" & tlist & "§" & (name of w) & linefeed
  end repeat
  return out
end tell
'''


def osa(script):
    try:
        r = subprocess.run(["osascript", "-"], input=script,
                            capture_output=True, text=True, timeout=15)
        return r.stdout
    except Exception:
        return ""


def idle_of(tty):
    try:
        return time.time() - os.stat(tty).st_mtime
    except Exception:
        return None


def short_proc(proc):
    """Compress the process chain into a short, friendly label."""
    p = proc.lower()
    if "claude" in p:
        label = "claude"
        if "--resume" in p:
            label = "claude (resumed)"
        extras = ""
        if "caffeinate" in p:
            extras += " ☕"          # kept awake
        if "sourcekit-lsp" in p or "xcode" in p:
            extras += " ⚙"          # swift LSP attached
        return label + extras
    # plain shell or other foreground command: show the leaf command word
    chain = re.split(r"\s*◂\s*", proc)
    leaf = chain[0].strip() if chain else proc.strip()
    leaf = leaf.lstrip("-")
    return (leaf.split() or ["shell"])[0] or "shell"


def collect():
    """Return list of dicts sorted by window id (stable numbering)."""
    rows = []
    for line in osa(OSA_LIST).splitlines():
        if "§" not in line:
            continue
        parts = line.split("§")
        if len(parts) < 3:
            continue
        try:
            wid = int(parts[0])
        except ValueError:
            continue
        ttys = [t for t in parts[1].split(",") if t.strip()]
        name = parts[2]

        # Terminal names look like "user — <glyph> <task> — <proc> — <WxH>".
        # We only rely on this for the pretty table; tiling needs just id+name.
        segs = name.split(" — ")
        title = segs[1].strip() if len(segs) >= 2 else segs[0].strip()
        dims, proc = "", ""
        if len(segs) >= 3:
            if re.match(r"^\d+×\d+$", segs[-1].strip()):
                dims = segs[-1].strip()
                proc = " — ".join(segs[2:-1]).strip()
            else:
                proc = " — ".join(segs[2:]).strip()

        glyph = ""
        task = title
        if title and not title[0].isalnum() and title[0] not in "/.~_-":
            glyph = title.split(" ", 1)[0]
            task = title[len(glyph):].strip() or title

        status = classify(glyph, proc, task)

        # pick the first stat-able tty for idle
        idle = None
        tty = ttys[0] if ttys else ""
        for cand in ttys:
            i = idle_of(cand)
            if i is not None:
                idle, tty = i, cand
                break

        rows.append({
            "wid": wid, "tty": tty, "task": task or "(untitled)",
            "proc": short_proc(proc), "rawproc": proc,
            "status": status, "idle": idle, "dims": dims,
        })
    rows.sort(key=lambda r: r["wid"])
    for n, r in enumerate(rows, 1):
        r["n"] = n
    return rows


# ---- formatting helpers --------------------------------------------------
def fmt_idle(s):
    if s is None:
        return "—"
    s = int(s)
    if s < 60:
        return f"{s}s"
    if s < 3600:
        return f"{s // 60}m"
    if s < 86400:
        return f"{s // 3600}h {(s % 3600) // 60}m"
    return f"{s // 86400}d"


STATUS_META = {        # label, ansi color, dot
    "working": ("working", "92", "●"),   # green
    "waiting": ("waiting", "93", "◌"),   # yellow
    "busy":    ("busy",    "96", "●"),   # cyan
    "shell":   ("shell",   "90", "·"),   # dim grey
    "other":   ("other",   "90", "·"),
}


def c(text, code, on):
    return f"\033[{code}m{text}\033[0m" if on else text


# ---- table renderer ------------------------------------------------------
def render_table(rows, color):
    if not rows:
        return "No open Terminal windows found.\n"
    width = shutil.get_terminal_size((100, 24)).columns
    n_w = max(2, len(str(len(rows))))
    st_w = 10
    id_w = 6
    proc_w = 18
    fixed = n_w + 2 + st_w + 2 + id_w + 2 + proc_w + 2
    task_w = max(20, width - fixed - 2)

    out = []
    head = (f"{'#':>{n_w}}  {'STATUS':<{st_w}}  {'IDLE':<{id_w}}  "
            f"{'SESSION':<{task_w}}  {'RUNNING':<{proc_w}}")
    out.append(c(head, "1;97", color))
    out.append(c("─" * min(width, len(head)), "90", color))

    counts = {}
    for r in rows:
        counts[r["status"]] = counts.get(r["status"], 0) + 1
        label, col, dot = STATUS_META.get(r["status"], STATUS_META["other"])
        st = f"{dot} {label}"
        st_pad = st + " " * max(0, st_w - len(label) - 2)
        task = r["task"]
        if len(task) > task_w:
            task = task[: task_w - 1] + "…"
        idle = fmt_idle(r["idle"])
        proc = r["proc"]
        if len(proc) > proc_w:
            proc = proc[: proc_w - 1] + "…"
        line = (f"{r['n']:>{n_w}}  {c(st_pad, col, color)}  {idle:<{id_w}}  "
                f"{task:<{task_w}}  {c(proc, '90', color)}")
        out.append(line)

    out.append("")
    parts = []
    for k in ("working", "waiting", "busy", "shell"):
        if counts.get(k):
            _, col, _ = STATUS_META[k]
            parts.append(c(f"{counts[k]} {k}", col, color))
    summary = f"{len(rows)} windows  —  " + "  ·  ".join(parts)
    stamp = time.strftime("%-I:%M:%S %p")
    out.append(summary + c(f"   ({stamp})", "90", color))
    out.append(c("Tile them: deck tile   ·   jump to one: deck go <#>", "90", color))
    return "\n".join(out) + "\n"


